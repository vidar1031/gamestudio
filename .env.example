# Copy to `.env.local` (recommended) and fill values.
# Do NOT commit `.env` / `.env.local` with real secrets.

# ==== Server storage ====
# STUDIO_STORAGE_ROOT=~/gamestudio_storage

# ==== AI provider (scripts generation) ====
STUDIO_AI_PROVIDER=openai
OPENAI_API_KEY=''

# Optional:
# STUDIO_AI_MODEL=gpt-5-mini
# STUDIO_AI_TIMEOUT_MS=60000
# STUDIO_AI_BASE_URL=https://api.openai.com/v1

# ==== Local Ollama (optional) ====
# Use with: STUDIO_AI_PROVIDER=ollama
# STUDIO_OLLAMA_URL=http://127.0.0.1:11434
# STUDIO_OLLAMA_MODEL=qwen3:8b

# ==== AI provider (background image generation) ====
# Provider options: sdwebui | comfyui | doubao
# STUDIO_BG_PROVIDER=sdwebui
#
# sdwebui
# SDWEBUI_BASE_URL=http://127.0.0.1:7860
#
# comfyui (recommended for continuous storyboard rendering)
# COMFYUI_BASE_URL=http://127.0.0.1:8188
# If ComfyUI shares model folders with SD-WebUI, set this to the shared "models" directory:
# STUDIO_COMFYUI_MODELS_ROOT=/Users/vidar/works/stable-diffusion-webui/models
# Optional default timeout for local generation (ms):
# STUDIO_BG_TIMEOUT_MS=120000
#
# doubao (Volcengine Ark Images API - Seedream 4.x)
# Endpoint:
# DOUBAO_ARK_IMAGES_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
# Model ID (or Endpoint ID like ep-2025****-**):
# DOUBAO_ARK_MODEL=doubao-seedream-4-0-250828
# Auth:
# DOUBAO_ARK_API_KEY=  # Authorization: Bearer <token>
# Or custom header (e.g. "X-Api-Key: xxx" / "Authorization: Bearer xxx"):
# DOUBAO_ARK_AUTH_HEADER=
# Optional prompt style hint
# DOUBAO_STYLE=picture_book
# Watermark flag (provider-dependent)
# DOUBAO_WATERMARK=false
# Optional request timeout (ms)
# STUDIO_BG_TIMEOUT_MS=60000

# ==== Doubao text (LLM) ====
# For text tasks (stories / prompt rewriting), use Ark chat completions API:
# DOUBAO_ARK_CHAT_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
# IMPORTANT: use a text-capable model here (NOT Seedream image models).
# DOUBAO_ARK_TEXT_MODEL=doubao-1-5-pro-32k-250115

# Optional (Proxy):
# If your terminal/Node cannot reach api.openai.com but browser can (e.g. Clash Verge),
# set a local HTTP proxy url here (Clash "Mixed Port" / "HTTP Port", often 7890).
# STUDIO_PROXY_URL=http://127.0.0.1:7890
# You can also use standard env vars HTTPS_PROXY / HTTP_PROXY, but STUDIO_PROXY_URL wins.
