{
  "name": "game-studio",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "predev:editor": "npm --workspace @game-studio/schema run build",
    "dev:editor": "npm --workspace @game-studio/editor run dev",
    "dev:server": "npm --workspace @game-studio/server run dev",
    "start:server": "bash ./start_server.sh",
    "stop:server": "bash ./stop_server.sh",
    "restart:server": "bash ./restart_server.sh",
    "build:editor": "npm --workspace @game-studio/editor run build",
    "build:packages": "npm --workspace @game-studio/schema run build && npm --workspace @game-studio/builder run build && npm --workspace @game-studio/runtime-pixi run build",
    "typecheck": "npm --workspace @game-studio/editor run typecheck",
    "sync:from-compose": "node tools/syncFromCompose.mjs",
    "lint": "echo \"(todo)\""
  }
}
